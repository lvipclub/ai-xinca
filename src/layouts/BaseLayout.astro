---
// BaseLayout.astro - Root layout
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
}
const { title, description, ogImage, ogType = 'website' } = Astro.props;
---
<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description || 'HVAC controls engineering hub. Ask about damper sizing, valve Cv, VAV setup, actuator torque — get answers backed by engineering knowledge.'} />
    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description || ''} />
    <meta property="og:type" content={ogType} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    {ogImage && <meta property="og:image:width" content="1200" />}
    {ogImage && <meta property="og:image:height" content="630" />}
    <!-- Twitter Card -->
    <meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}
    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>{title} | ai.xinca.com</title>
  </head>
  <body class="min-h-screen flex flex-col bg-white text-[#666]">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
