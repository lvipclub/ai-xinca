---
// BaseLayout.astro - Root layout
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
}
const { title, description, ogImage, ogType = 'website' } = Astro.props;
---
<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description || 'HVAC controls engineering hub. Ask about damper sizing, valve Cv, VAV setup, actuator torque — get answers backed by engineering knowledge.'} />
    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description || ''} />
    <meta property="og:type" content={ogType} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    {ogImage && <meta property="og:image:width" content="1200" />}
    {ogImage && <meta property="og:image:height" content="630" />}
    <!-- Twitter Card -->
    <meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}
    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>{title} | ai.xinca.com</title>
    <!-- Google Analytics 4 -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-MLH9M91H5W"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-MLH9M91H5W');

      // Track article page views
      if (window.location.pathname.startsWith('/a/') && window.location.pathname !== '/a/') {
        gtag('event', 'article_view', {
          article_slug: window.location.pathname.replace('/a/', '').replace(/\/$/, ''),
          page_title: document.title,
          page_location: window.location.pathname
        });
      }

      // Track category page views
      if (window.location.pathname.match(/^\/kb\/[a-z]+\/$/) && !window.location.pathname.match(/\/kb\/q\//)) {
        gtag('event', 'category_view', {
          category: window.location.pathname.replace('/kb/', '').replace(/\/$/, ''),
          page_location: window.location.pathname
        });
      }

      // Track Q&A page views
      if (window.location.pathname.startsWith('/kb/q/')) {
        gtag('event', 'qa_view', {
          qa_id: window.location.pathname.replace('/kb/q/', '').replace(/\/$/, ''),
          page_location: window.location.pathname
        });
      }

      // Track leaderboard clicks (generic handler)
      document.addEventListener('click', function(e) {
        var el = e.target.closest('[data-ga-event]');
        if (!el) return;
        var eventData = { page_location: window.location.pathname };
        for (var i = 0; i < el.attributes.length; i++) {
          var attr = el.attributes[i];
          if (attr.name.startsWith('data-ga-')) {
            eventData[attr.name.replace('data-ga-', '')] = attr.value;
          }
        }
        gtag('event', el.dataset.gaEvent, eventData);
      });

      // Track outbound Telegram clicks
      document.addEventListener('click', function(e) {
        var el = e.target.closest('a[href*="t.me/hai5bot"]');
        if (el) {
          gtag('event', 'telegram_click', { page_location: window.location.pathname });
        }
      });

      // Track FAQ search usage
      var chatInput = document.getElementById('chat-input');
      if (chatInput) {
        chatInput.addEventListener('keydown', function(e) {
          if (e.key === 'Enter' && chatInput.value.trim()) {
            gtag('event', 'search_query', { search_term: chatInput.value.trim().substring(0, 100), page_location: window.location.pathname });
          }
        });
        var chatSend = document.getElementById('chat-send');
        if (chatSend) {
          chatSend.addEventListener('click', function() {
            if (chatInput.value.trim()) {
              gtag('event', 'search_query', { search_term: chatInput.value.trim().substring(0, 100), page_location: window.location.pathname });
            }
          });
        }
      }
    </script>
  </head>
  <body class="min-h-screen flex flex-col bg-white text-[#666]">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
