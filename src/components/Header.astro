---
// Header.astro - XINCA branding header, light theme matching xinca.com
---
<header class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-gray-200 shadow-sm">
  <div class="max-w-[1080px] mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo / Brand -->
      <a href="/" class="flex items-center gap-3 group">
        <img src="/logo.png" alt="XINCA" class="h-10 w-auto" />
        <span class="text-xl font-bold tracking-tight" style="font-family:'Trebuchet MS',Trebuchet,Helvetica,Arial,Lucida,sans-serif">
          <span class="text-[#32373c]">XINCA</span>
        </span>
      </a>

      <!-- Navigation -->
      <nav class="hidden md:flex items-center gap-8">
        <a href="/" class="text-[#666] hover:text-[#2ea3f2] transition-colors text-sm font-medium">Home</a>
        <a href="/qa" class="text-[#666] hover:text-[#2ea3f2] transition-colors text-sm font-medium">Q&A</a>
        <a href="#" class="text-gray-400 cursor-not-allowed text-sm font-medium" title="Coming soon">Tools</a>
        <a href="https://shop.xinca.com" target="_blank" rel="noopener"
           class="btn-accent text-sm px-4 py-2">
          Shop
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
          </svg>
        </a>
      </nav>

      <!-- Mobile menu button -->
      <button id="mobile-menu-btn" class="md:hidden p-2 text-[#666] hover:text-[#333]" aria-label="Menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>

    <!-- Mobile menu (hidden by default) -->
    <div id="mobile-menu" class="hidden md:hidden pb-4 border-t border-gray-100 mt-2 pt-2">
      <a href="/" class="block py-2 text-[#666] hover:text-[#2ea3f2] transition-colors">Home</a>
      <a href="/qa" class="block py-2 text-[#666] hover:text-[#2ea3f2] transition-colors">Q&A</a>
      <a href="#" class="block py-2 text-gray-400">Tools (Coming Soon)</a>
      <a href="https://shop.xinca.com" target="_blank" rel="noopener"
         class="block py-2 text-[#2ea3f2] hover:text-[#7EBEC5] transition-colors">
        Shop →
      </a>
    </div>
  </div>
</header>

<script>
  document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
    document.getElementById('mobile-menu')?.classList.toggle('hidden');
  });
</script>
