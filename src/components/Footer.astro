---
// Footer.astro - XINCA branding footer matching xinca.com
---
<footer class="bg-[#050505] border-t border-xinca-cyan/20 mt-auto">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
      <!-- Categories -->
      <div>
        <h3 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">Categories</h3>
        <ul class="space-y-2">
          <li><a href="/faq/air" class="text-gray-400 hover:text-xinca-cyan transition-colors text-sm">Air-side HVAC</a></li>
          <li><a href="/faq/water" class="text-gray-400 hover:text-xinca-cyan transition-colors text-sm">Water-side HVAC</a></li>
          <li><a href="/faq/controls" class="text-gray-400 hover:text-xinca-cyan transition-colors text-sm">Building Controls</a></li>
          <li><a href="/faq/products" class="text-gray-400 hover:text-xinca-cyan transition-colors text-sm">Products</a></li>
        </ul>
      </div>

      <!-- Resources -->
      <div>
        <h3 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">Resources</h3>
        <ul class="space-y-2">
          <li><a href="/qa" class="text-gray-400 hover:text-xinca-cyan transition-colors text-sm">Q&A</a></li>
          <li><a href="#" class="text-gray-500 text-sm" title="Coming soon">Tools</a></li>
          <li><a href="/faq" class="text-gray-400 hover:text-xinca-cyan transition-colors text-sm">FAQ</a></li>
        </ul>
      </div>

      <!-- XINCA -->
      <div>
        <h3 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">XINCA</h3>
        <ul class="space-y-2">
          <li><a href="https://shop.xinca.com" target="_blank" rel="noopener" class="text-gray-400 hover:text-xinca-cyan transition-colors text-sm">shop.xinca.com</a></li>
          <li><a href="https://xinca.com" target="_blank" rel="noopener" class="text-gray-400 hover:text-xinca-cyan transition-colors text-sm">xinca.com</a></li>
          <li><a href="https://linkedin.com/company/xinca-hvac" target="_blank" rel="noopener" class="text-gray-400 hover:text-xinca-cyan transition-colors text-sm">LinkedIn</a></li>
        </ul>
      </div>

      <!-- About -->
      <div>
        <h3 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">About</h3>
        <p class="text-gray-400 text-sm leading-relaxed">
          XINCA is a brand of XASER Green Technology Company Limited, Hong Kong.
        </p>
        <p class="text-gray-600 text-xs mt-3">
          &copy; {new Date().getFullYear()} ai.xinca.com
        </p>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-10 pt-6 border-t border-xinca-border flex items-center justify-center">
      <p class="text-gray-500 text-xs text-center">
        XINCA is a brand of XASER Green Technology Company Limited, Hong Kong.
      </p>
    </div>
  </div>
</footer>
