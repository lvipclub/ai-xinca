---
// index.astro - Chatbot-first landing page for ai.xinca.com (light theme)
import BaseLayout from '../layouts/BaseLayout.astro';
import ChatWidget from '../components/ChatWidget.astro';
import qaData from '../data/seed-qa.json';

// Pick 8 demo Q&As for the "Popular Questions" section
const demoQuestions = qaData.slice(0, 8);
---

<BaseLayout 
  title="XINCA HVAC Controls Engineering"
  description="HVAC controls engineering, answered. Ask anything about damper sizing, valve Cv, VAV setup, actuator torque — get answers backed by engineering knowledge."
>
  <!-- Hero Section -->
  <section class="relative overflow-hidden bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28">
      <div class="text-center mb-10">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold leading-tight mb-4 text-[#333]" style="font-family:'Trebuchet MS',Trebuchet,Helvetica,Arial,Lucida,sans-serif">
          HVAC controls engineering, <span class="gradient-text">answered.</span>
        </h1>
        <p class="text-lg md:text-xl text-[#666] max-w-2xl mx-auto leading-relaxed">
          Ask anything about damper sizing, valve Cv, VAV setup, actuator torque — get answers backed by engineering knowledge.
        </p>
      </div>

      <!-- Chatbot Input - FRONT AND CENTER -->
      <div class="max-w-2xl mx-auto">
        <ChatWidget compact={false} />
      </div>
    </div>
  </section>

  <!-- 4 Value Cards (2x2 grid) -->
  <section class="border-t border-[#e5e5e5] bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- FAQ (machines only) -->
        <div class="card text-left">
          <div class="text-2xl mb-3">🔍</div>
          <h3 class="text-lg font-semibold text-[#333] mb-2" style="font-family:'Trebuchet MS',Trebuchet,Helvetica,Arial,Lucida,sans-serif">FAQ</h3>
          <p class="text-[#666] text-sm leading-relaxed">
            Searchable HVAC controls knowledge base — air, water, controls, and products
          </p>
        </div>

        <!-- Tools -->
        <div class="card text-left opacity-70">
          <div class="text-2xl mb-3">🔧</div>
          <h3 class="text-lg font-semibold text-[#333] mb-2" style="font-family:'Trebuchet MS',Trebuchet,Helvetica,Arial,Lucida,sans-serif">Tools</h3>
          <p class="text-[#666] text-sm leading-relaxed">
            Cross-brand pairing matrix — in development
          </p>
        </div>

        <!-- AI Chatbot -->
        <div class="card text-left border-[#7EBEC5]">
          <div class="text-2xl mb-3">🤖</div>
          <h3 class="text-lg font-semibold text-[#7EBEC5] mb-2" style="font-family:'Trebuchet MS',Trebuchet,Helvetica,Arial,Lucida,sans-serif">AI Chatbot</h3>
          <p class="text-[#666] text-sm leading-relaxed">
            Ask HVAC101 questions, get citations
          </p>
        </div>

        <!-- Knowledge -->
        <div class="card text-left">
          <div class="text-2xl mb-3">📚</div>
          <h3 class="text-lg font-semibold text-[#333] mb-2" style="font-family:'Trebuchet MS',Trebuchet,Helvetica,Arial,Lucida,sans-serif">Knowledge</h3>
          <p class="text-[#666] text-sm leading-relaxed">
            Engineering articles and practical guides for professionals
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Popular Questions Section -->
  <section class="border-t border-[#e5e5e5] bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <h2 class="text-3xl md:text-4xl font-bold text-center text-[#333] mb-4" style="font-family:'Trebuchet MS',Trebuchet,Helvetica,Arial,Lucida,sans-serif">
        Popular <span class="gradient-text">Questions</span>
      </h2>
      <p class="text-lg text-[#666] text-center max-w-2xl mx-auto mb-10">
        See what visitors are asking the chatbot
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4" id="popular-questions">
        {demoQuestions.map(q => (
          <a href={`/qa/${q.id}`} class="card card-hover cursor-pointer group block no-underline">
            <h3 class="text-[#333] font-medium text-sm leading-snug mb-2 group-hover:text-[#2ea3f2] transition-colors">
              {q.question}
            </h3>
            <p class="text-[#666] text-xs leading-relaxed line-clamp-2">
              {q.answer.substring(0, 150)}...
            </p>
            <span class="badge-category mt-2">
              {q.category}
            </span>
          </a>
        ))}
      </div>

      <div class="text-center mt-8">
        <a href="/qa" class="btn-primary">
          View All Q&A
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
          </svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
