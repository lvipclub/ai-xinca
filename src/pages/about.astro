---
// about.astro - About page for ai.xinca.com
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="About"
  description="About ai.xinca.com — the HVAC controls engineering knowledge hub by XINCA."
>
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <h1 class="section-title">About <span class="gradient-text">ai.xinca.com</span></h1>
    
    <div class="prose prose-invert max-w-none mt-8 space-y-6">
      <div class="card">
        <h2 class="text-2xl font-bold text-white mb-4">HVAC Controls Engineering Knowledge Hub</h2>
        <p class="text-gray-300 leading-relaxed">
          ai.xinca.com is the knowledge hub for HVAC controls engineering professionals. 
          We cover dampers, actuators, valves, sensors, and building automation — not 
          chillers, boilers, or ducting. If you're specifying damper actuators, sizing 
          control valves, selecting VAV controllers, or integrating BACnet networks, 
          this is your resource.
        </p>
      </div>

      <div class="card">
        <h2 class="text-2xl font-bold text-white mb-4">What We Offer</h2>
        <ul class="space-y-3 text-gray-300">
          <li class="flex items-start gap-3">
            <span class="text-xinca-cyan mt-1">▸</span>
            <span><strong class="text-white">AI Chatbot</strong> — Ask HVAC101 questions, get answers backed by engineering knowledge with citations.</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-xinca-cyan mt-1">▸</span>
            <span><strong class="text-white">137 FAQ Entries</strong> — JSON-LD structured for search engines, covering air-side, water-side, controls, and products.</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-xinca-cyan mt-1">▸</span>
            <span><strong class="text-white">Cross-Brand Tools</strong> — Pairing matrices and compatibility tools (coming soon).</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-xinca-cyan mt-1">▸</span>
            <span><strong class="text-white">Knowledge Articles</strong> — Listicles and engineering content published to LinkedIn and X.</span>
          </li>
        </ul>
      </div>

      <div class="card">
        <h2 class="text-2xl font-bold text-white mb-4">About XINCA</h2>
        <p class="text-gray-300 leading-relaxed mb-4">
          XINCA is an ecommerce partner of authorized HVAC controls suppliers. 
          We help engineers and contractors source dampers, actuators, valves, 
          sensors, and building automation products from leading manufacturers 
          including Belimo, Honeywell, Johnson Controls, and Siemens.
        </p>
        <p class="text-gray-300 leading-relaxed">
          XINCA is a brand of XASER Green Technology Company Limited, Hong Kong.
        </p>
        <div class="flex gap-4 mt-4">
          <a href="https://xinca.com" target="_blank" rel="noopener" class="btn-primary text-sm">xinca.com</a>
          <a href="https://shop.xinca.com" target="_blank" rel="noopener" class="btn-secondary text-sm">shop.xinca.com</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
