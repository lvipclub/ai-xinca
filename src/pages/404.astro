---
// 404.astro - Not found page (light theme)
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Page Not Found">
  <section class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-32 text-center">
    <div class="text-8xl font-extrabold gradient-text mb-6">404</div>
    <h1 class="text-2xl font-bold text-[#333] mb-4" style="font-family:'Trebuchet MS',Trebuchet,Helvetica,Arial,Lucida,sans-serif">Page Not Found</h1>
    <p class="text-[#666] mb-8 max-w-md mx-auto">
      The page you're looking for doesn't exist or has been moved. 
      Let us help you find the HVAC engineering answers you need.
    </p>
    <div class="flex flex-wrap justify-center gap-4">
      <a href="/" class="btn-primary">
        Go Home
      </a>
      <a href="/kb" class="btn-outline">
        Browse Knowledge Base
      </a>
    </div>
  </section>
</BaseLayout>
