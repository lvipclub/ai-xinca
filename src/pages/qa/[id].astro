---
// qa/[id].astro - Individual Q&A template page
import BaseLayout from '../../layouts/BaseLayout.astro';
import qaData from '../../data/seed-qa.json';

export function getStaticPaths() {
  return qaData.map(q => ({ params: { id: String(q.id) } }));
}

const { id } = Astro.params;
const qa = qaData.find(q => String(q.id) === id);

if (!qa) {
  return Astro.redirect('/qa');
}

// Category display names
const catNames = {
  air: 'Air-side',
  hydronic: 'Hydronic',
  actuators: 'Actuators',
  controls: 'Controls',
  standards: 'Standards',
  water: 'Water-side',
  products: 'Products',
  sensors: 'Sensors',
  valves: 'Valves',
  dampers: 'Dampers',
  bms: 'BMS',
};

// Build JSON-LD QAPage structured data
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "QAPage",
  "mainEntity": {
    "@type": "Question",
    "name": qa.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": qa.answer.substring(0, 5000)
    }
  }
};

const pageTitle = qa.question.length > 60 ? qa.question.substring(0, 60) + '...' : qa.question;
---

<BaseLayout 
  title={pageTitle}
  description={qa.answer.substring(0, 160).replace(/\n/g, ' ')}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)}></script>

  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-sm text-gray-400 mb-8">
      <a href="/" class="hover:text-[#2ea3f2] transition-colors">Home</a>
      <span class="text-gray-300">/</span>
      <a href="/qa" class="hover:text-[#2ea3f2] transition-colors">Q&A</a>
      <span class="text-gray-300">/</span>
      <span class="text-[#2ea3f2] truncate max-w-[300px]">{qa.question.substring(0, 50)}...</span>
    </nav>

    <!-- Question Title -->
    <h1 class="text-2xl md:text-3xl font-bold text-[#333] mb-6 leading-tight" style="font-family:'Trebuchet MS',Trebuchet,Helvetica,Arial,Lucida,sans-serif">
      {qa.question}
    </h1>

    <!-- Meta badges -->
    <div class="flex flex-wrap items-center gap-3 mb-8">
      <span class="badge-category">
        {catNames[qa.category] || qa.category}
      </span>
      {qa.tags && qa.tags.map(t => (
        <span class="tag-pill">#{t}</span>
      ))}
    </div>

    <!-- Full Answer -->
    <div class="card mb-8">
      <p class="text-[#666] leading-relaxed whitespace-pre-line text-[15px]">
        {qa.answer}
      </p>
    </div>

    <!-- Social Share Buttons -->
    <div class="flex items-center gap-4 mb-8 pt-4 border-t border-[#e5e5e5]">
      <span class="text-sm text-gray-400">Share:</span>
      <!-- Twitter/X -->
      <a href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(qa.question)}&url=${encodeURIComponent(`https://ai.xinca.com/qa/${qa.id}`)}`}
         target="_blank" rel="noopener"
         class="inline-flex items-center gap-1.5 text-sm text-gray-500 hover:text-[#2ea3f2] transition-colors"
         title="Share on X">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        X
      </a>
      <!-- LinkedIn -->
      <a href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(`https://ai.xinca.com/qa/${qa.id}`)}`}
         target="_blank" rel="noopener"
         class="inline-flex items-center gap-1.5 text-sm text-gray-500 hover:text-[#2ea3f2] transition-colors"
         title="Share on LinkedIn">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        LinkedIn
      </a>
    </div>

    <!-- Back to Q&A -->
    <div class="text-center">
      <a href="/qa" class="btn-outline">
        ← Back to All Q&A
      </a>
    </div>
  </section>
</BaseLayout>
