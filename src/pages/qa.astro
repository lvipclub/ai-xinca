---
// qa.astro - Popular Q&A listing page (light theme, 3-column layout, no answers)
import BaseLayout from '../layouts/BaseLayout.astro';
import qaData from '../data/seed-qa.json';

const allQa = qaData;
const totalCount = allQa.length;

// Top 10 latest (by ID, highest first)
const latest = [...allQa].sort((a, b) => b.id - a.id).slice(0, 10);

// Top 10 "this month" — for seed data, simulate with IDs 20-29
const thisMonth = allQa.filter(q => q.id >= 10 && q.id <= 19).slice(0, 10);

// Top 10 all time — IDs 1-10
const allTime = [...allQa].sort((a, b) => a.id - b.id).slice(0, 10);

// Category display names
const catNames = {
  air: 'Air-side',
  hydronic: 'Hydronic',
  actuators: 'Actuators',
  controls: 'Controls',
  standards: 'Standards',
  water: 'Water-side',
  products: 'Products',
  sensors: 'Sensors',
  valves: 'Valves',
  dampers: 'Dampers',
  bms: 'BMS',
};
---

<BaseLayout 
  title="Popular Questions"
  description="Browse popular HVAC controls engineering questions and answers. Top questions about damper sizing, valve selection, actuator torque, and more."
>
  <section class="max-w-[1080px] mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="mb-10">
      <h1 class="text-3xl md:text-4xl font-bold text-[#333] mb-4" style="font-family:'Trebuchet MS',Trebuchet,Helvetica,Arial,Lucida,sans-serif">
        Popular <span class="gradient-text">Questions</span>
      </h1>
      <p class="text-lg text-[#666] max-w-2xl mb-2">
        Top HVAC controls engineering questions asked by our community
      </p>
      <p class="text-sm text-gray-400 flex items-center gap-1">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
        {totalCount} total Q&A entries
      </p>
    </div>

    <!-- Search/Filter -->
    <div class="card mb-10 flex items-center gap-3">
      <svg class="w-5 h-5 text-gray-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
              d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
      </svg>
      <input 
        type="text" 
        id="qa-filter"
        placeholder="Filter questions..."
        class="w-full bg-transparent text-[#333] placeholder-gray-400 focus:outline-none text-base"
      />
    </div>

    <!-- Top 10 Latest -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold text-[#333] mb-6" style="font-family:'Trebuchet MS',Trebuchet,Helvetica,Arial,Lucida,sans-serif">
        🆕 <span class="gradient-text">Top 10 Latest</span>
      </h2>
      <div class="qa-section space-y-0" data-section="latest">
        {latest.map((q, idx) => (
          <a href={`/qa/${q.id}`} class="qa-card block border-b border-[#e5e5e5] py-3.5 hover:bg-[#f8f9fa] transition-colors no-underline">
            <div class="grid grid-cols-12 gap-4 items-center">
              <div class="col-span-7">
                <h3 class="text-[#333] font-medium text-sm leading-snug hover:text-[#2ea3f2] transition-colors">
                  {q.question}
                </h3>
              </div>
              <div class="col-span-2">
                <span class="badge-category text-xs whitespace-nowrap">
                  {catNames[q.category] || q.category}
                </span>
              </div>
              <div class="col-span-3">
                {q.tags && q.tags.length > 0 && (
                  <div class="flex flex-wrap gap-1">
                    {q.tags.slice(0, 3).map(t => (
                      <span class="tag-pill">#{t}</span>
                    ))}
                  </div>
                )}
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- Top 10 This Month -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold text-[#333] mb-6" style="font-family:'Trebuchet MS',Trebuchet,Helvetica,Arial,Lucida,sans-serif">
        📅 <span class="gradient-text">Top 10 This Month</span>
      </h2>
      <div class="qa-section space-y-0" data-section="month">
        {thisMonth.map((q, idx) => (
          <a href={`/qa/${q.id}`} class="qa-card block border-b border-[#e5e5e5] py-3.5 hover:bg-[#f8f9fa] transition-colors no-underline">
            <div class="grid grid-cols-12 gap-4 items-center">
              <div class="col-span-7">
                <h3 class="text-[#333] font-medium text-sm leading-snug hover:text-[#2ea3f2] transition-colors">
                  {q.question}
                </h3>
              </div>
              <div class="col-span-2">
                <span class="badge-category text-xs whitespace-nowrap">
                  {catNames[q.category] || q.category}
                </span>
              </div>
              <div class="col-span-3">
                {q.tags && q.tags.length > 0 && (
                  <div class="flex flex-wrap gap-1">
                    {q.tags.slice(0, 3).map(t => (
                      <span class="tag-pill">#{t}</span>
                    ))}
                  </div>
                )}
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- Top 10 All Time -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold text-[#333] mb-6" style="font-family:'Trebuchet MS',Trebuchet,Helvetica,Arial,Lucida,sans-serif">
        🏆 <span class="gradient-text">Top 10 All Time</span>
      </h2>
      <div class="qa-section space-y-0" data-section="alltime">
        {allTime.map((q, idx) => (
          <a href={`/qa/${q.id}`} class="qa-card block border-b border-[#e5e5e5] py-3.5 hover:bg-[#f8f9fa] transition-colors no-underline">
            <div class="grid grid-cols-12 gap-4 items-center">
              <div class="col-span-7">
                <h3 class="text-[#333] font-medium text-sm leading-snug hover:text-[#2ea3f2] transition-colors">
                  {q.question}
                </h3>
              </div>
              <div class="col-span-2">
                <span class="badge-category text-xs whitespace-nowrap">
                  {catNames[q.category] || q.category}
                </span>
              </div>
              <div class="col-span-3">
                {q.tags && q.tags.length > 0 && (
                  <div class="flex flex-wrap gap-1">
                    {q.tags.slice(0, 3).map(t => (
                      <span class="tag-pill">#{t}</span>
                    ))}
                  </div>
                )}
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>
  </section>
</BaseLayout>

<script>
  const filterInput = document.getElementById('qa-filter');
  
  filterInput?.addEventListener('input', (e) => {
    const query = e.target.value.toLowerCase().trim();
    
    document.querySelectorAll('.qa-card').forEach(card => {
      const text = card.textContent?.toLowerCase() || '';
      if (!query || text.includes(query)) {
        card.classList.remove('hidden');
      } else {
        card.classList.add('hidden');
      }
    });

    // Hide empty sections
    document.querySelectorAll('.qa-section').forEach(section => {
      const hasVisible = section.querySelectorAll('.qa-card:not(.hidden)').length > 0;
      const heading = section.previousElementSibling;
      if (heading) heading.classList.toggle('hidden', !hasVisible);
      section.classList.toggle('hidden', !hasVisible);
    });
  });
</script>
