---
// faq/index.astro - FAQ Hub (SEO-only, for crawlers). Humans use the chatbot.
import BaseLayout from '../../layouts/BaseLayout.astro';
import categories from '../../content/faq/categories.json';
---

<BaseLayout 
  title="FAQ — HVAC Controls Engineering"
  description="Structured FAQ knowledge base for HVAC controls engineering. 137 entries covering air-side, water-side, building controls, and products."
>
  <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="mb-10">
      <h1 class="section-title">FAQ <span class="gradient-text">Knowledge Base</span></h1>
      <p class="text-gray-500 text-sm">
        137 structured FAQ entries for search engine indexing
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {Object.entries(categories.categories).map(([slug, cat]) => (
        <a href={`/faq/${slug}`} class="card group">
          <div class="flex items-start justify-between mb-4">
            <h3 class="text-lg font-semibold text-white group-hover:text-xinca-cyan transition-colors">
              {cat.name}
            </h3>
            <span class="text-xs text-gray-500 bg-[#0a0a0a] px-2 py-1 rounded">
              {cat.count} entries
            </span>
          </div>
          <p class="text-gray-400 text-sm">{cat.description}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
