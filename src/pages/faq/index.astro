---
// faq/index.astro - FAQ Hub (light theme)
import BaseLayout from '../../layouts/BaseLayout.astro';
import categories from '../../content/faq/categories.json';
---

<BaseLayout 
  title="FAQ — HVAC Controls Engineering"
  description="Structured FAQ knowledge base for HVAC controls engineering. A growing library covering air-side, water-side, building controls, and products."
>
  <section class="max-w-[1080px] mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="mb-10">
      <h1 class="text-3xl md:text-4xl font-bold text-[#333] mb-4" style="font-family:'Trebuchet MS',Trebuchet,Helvetica,Arial,Lucida,sans-serif">
        FAQ <span class="gradient-text">Knowledge Base</span>
      </h1>
      <p class="text-sm text-gray-400">
        A growing library of structured FAQ entries for search engine indexing
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {Object.entries(categories.categories).map(([slug, cat]) => (
        <a href={`/faq/${slug}`} class="card card-hover group no-underline">
          <div class="flex items-start justify-between mb-4">
            <h3 class="text-lg font-semibold text-[#333] group-hover:text-[#2ea3f2] transition-colors" style="font-family:'Trebuchet MS',Trebuchet,Helvetica,Arial,Lucida,sans-serif">
              {cat.name}
            </h3>
            <span class="text-xs text-[#666] bg-[#f8f9fa] px-2 py-1 rounded border border-[#e5e5e5]">
              {cat.count} entries
            </span>
          </div>
          <p class="text-[#666] text-sm">{cat.description}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
